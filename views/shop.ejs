                    <a href="#" class="flex flex-col items-center gap-2 group min-w-[60px]">
                        <div
                            class="w-12 h-12 md:w-16 md:h-16 rounded-full bg-zinc-100 flex items-center justify-center text-zinc-600 group-hover:bg-zinc-800 group-hover:text-white transition-all shadow-sm">
                            <i class="ri-footprint-line text-lg md:text-xl"></i>
                        </div>
                        <span class="text-xs font-medium text-zinc-600 group-hover:text-black">Shoes</span>
                    </a>
                    <a href="#" class="flex flex-col items-center gap-2 group min-w-[60px]">
                        <div
                            class="w-12 h-12 md:w-16 md:h-16 rounded-full bg-zinc-100 flex items-center justify-center text-zinc-600 group-hover:bg-zinc-800 group-hover:text-white transition-all shadow-sm">
