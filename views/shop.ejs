                                        </div>

                                        <!-- Text Info -->
                                        <div>
                                            <h3 class="text-base font-medium text-zinc-900 mb-1 leading-snug">
                                                <%= product.name %>
                                            </h3>

                                            <!-- Optional Brand Name (Generic for now) -->
                                            <p class="text-xs text-zinc-400 mb-2">Scatch Essentials</p>

                                            <div class="flex items-center justify-between">
                                                <h4 class="text-sm font-semibold text-zinc-900">₹ <%= product.price %>
                                                </h4>
                                                <!-- Heart icon for wishlist -->
                                                <% let isWishlistedProduct=user.wishlist.indexOf(product._id) !==-1; %>
                                                    <a href="/addtowishlist/<%= product._id %>"
                                                        class="<%= isWishlistedProduct ? 'text-red-500' : 'text-zinc-300 hover:text-red-500' %> transition-colors">
                                                        <i
                                                            class="<%= isWishlistedProduct ? 'ri-heart-fill' : 'ri-heart-line' %>"></i>
                                                    </a>
                                            </div>
                                        </div>
                                    </div>
                                    <% }) %>
                            </div>

                            <% if (products.length===0) { %>
                                <div class="w-full py-32 text-center">
                                    <p class="text-zinc-400 text-sm uppercase tracking-widest">No products available</p>
                                </div>
                                <% } %>
                </div>
            </div>

            <script>
                // Flash Sale Horizontal Scroll
                const flashContainer = document.getElementById('flash-sale-container');
                const flashPrev = document.getElementById('flash-prev');
                const flashNext = document.getElementById('flash-next');

                if (flashContainer && flashPrev && flashNext) {
                    flashPrev.addEventListener('click', () => {
                        flashContainer.scrollBy({ left: -300, behavior: 'smooth' });
                    });
                    flashNext.addEventListener('click', () => {
                        flashContainer.scrollBy({ left: 300, behavior: 'smooth' });
                    });
                }
            </script>
