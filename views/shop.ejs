                                            class="ri-arrow-right-line text-lg"></i></button>
                                </div>
                            </div>

                            <!-- Flash Sale Grid (Scrollable) -->
                            <div id="flash-sale-container"
                                class="flex overflow-x-auto gap-4 scroll-smooth snap-x scrollbar-hide pb-4">
                                <% flashSaleProducts.forEach(function(item) { %>
                                    <div class="group cursor-pointer min-w-[200px] md:min-w-[260px] snap-start">
                                        <div
                                            class="aspect-square bg-[#F3F4F6] rounded-xl mb-3 overflow-hidden relative flex items-center justify-center">
                                            <img src="/images/uploads/<%= item.image %>"
                                                class="w-[85%] mix-blend-multiply group-hover:scale-110 transition-transform duration-500 object-cover h-full w-full">
                                            <% let isWishlisted=user.wishlist.indexOf(item._id) !==-1; %>
                                                <a href="/addtowishlist/<%= item._id %>"
                                                    class="absolute top-2 right-2 w-7 h-7 bg-white rounded-full flex items-center justify-center <%= isWishlisted ? 'text-red-500' : 'text-zinc-300 hover:text-red-500' %> transition-colors shadow-sm"><i
                                                        class="ri-heart-fill"></i></a>
                                                <a href="/addtocart/<%= item._id %>"
                                                    class="absolute bottom-2 right-2 w-8 h-8 bg-zinc-900 text-white rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity shadow-md"><i
                                                        class="ri-add-line"></i></a>
                                        </div>
                                        <h3 class="font-bold text-zinc-900 text-sm leading-tight mb-1 pr-4 truncate">
                                            <%= item.name %>
                                        </h3>
                                        <div class="flex items-baseline gap-2">
                                            <% if(item.discount> 0) { %>
                                                <span class="font-bold text-zinc-900 text-base">₹ <%= item.price -
                                                        item.discount %></span>
                                                <span
                                                    class="text-[10px] text-red-500 line-through decoration-red-500 font-medium">₹
                                                    <%= item.price %>
                                                </span>
                                                <% } else { %>
                                                    <span class="font-bold text-zinc-900 text-base">₹ <%= item.price %>
                                                    </span>
                                                    <% } %>
                                        </div>
                                    </div>
                                    <% }) %>
                            </div>
                        </div>
                        <% } %>

                            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 xl:grid-cols-5 gap-x-6 gap-y-10">
                                <% products.forEach(function(product){ %>
                                    <div class="group cursor-pointer">
                                        <!-- Minimalist Image container -->
                                        <div class="w-full aspect-[3/4] bg-zinc-50 mb-4 overflow-hidden relative">
                                            <!-- 'New' Tag if needed, simple dot style -->
                                            <div
                                                class="absolute top-4 left-4 bg-black text-white text-[10px] uppercase font-bold px-2 py-1 tracking-wider opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                                                New
                                            </div>

                                            <!-- Image -->
                                            <img class="h-full w-full object-cover object-center mix-blend-multiply group-hover:scale-105 transition-transform duration-700 ease-in-out"
                                                src="/images/uploads/<%= product.image %>" alt="<%= product.name %>">

                                            <!-- Quick Add Button (appears on hover) -->
